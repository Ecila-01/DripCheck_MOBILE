{
  "expo": {
    "name": "DripCheck",
    "slug": "dripcheck",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./image_upload/DripCheckLogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./image_upload/DripCheckLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dripcheck.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./image_upload/DripCheckLogo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.dripcheck.app",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES" 
      ]
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./image_upload/DripCheckNotificationIcon.png",
          "color": "#FFFFFF",
          "permissions": {
            "notifications": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share outfit ideas.",
          "cameraPermission": "The app accesses your camera to let you take photos of your clothes."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d47b56ed-4d14-4cd7-a2c0-45b38e413805"
      }
    }
  }
}